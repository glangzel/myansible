# 基本設定
set $mod Mod4
font pango:JetBrains Mono 10

# Gruvboxカラーの定義
set $bg #282828
set $red #cc241d
set $green #98971a
set $yellow #d79921
set $blue #458588
set $purple #b16286
set $aqua #689d6a
set $gray #a89984


# ウィンドウの色設定
# class                 border  backgr. text    indicator child_border
client.focused          $yellow $yellow $bg     $purple   $yellow
client.focused_inactive $bg     $bg     $gray   $bg       $bg
client.unfocused        $bg     $bg     $gray   $bg       $bg
client.urgent           $red    $red    $bg     $red      $red

# 新しく開くウィンドウのボーダー設定 (タイトルバーなし、枠線のみ)
# pixel 2 の 2 は枠線の太さです。0 にすると完全に枠も消えます。
default_border pixel 2
default_floating_border pixel 2

# 既に開いているウィンドウに対しても適用するための汎用設定
for_window [class=".*"] border pixel 2

# 隙間 (Gaps) の設定

gaps inner 10

gaps outer 5

# Rofiの起動設定 (画像1枚目のスタイル)
bindsym $mod+d exec --no-startup-id rofi -show run

# 自動起動
exec_always --no-startup-id picom -f
exec_always --no-startup-id $HOME/.config/polybar/launch.sh
# 壁紙設定 (画像に合わせて暗めのものを用意してください)
